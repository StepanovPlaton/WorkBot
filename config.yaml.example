telegram:
  token: paste-your-telegram-bot-token-here
  allowed_user_ids: []
  proxy:
    enabled: false
    scheme: socks5
    host: ""
    port: 1080
    username: ""
    password: ""

openproject:
  scheme: https
  host: ""
  port:
  base_path: ""
  token: paste-your-openproject-api-token-here
  timeout_seconds: 30
  display:
    story_points_field: storyPoints
    department_field: customField2
    default_boards: {}
    # OpenProject display name → Telegram username (без @)
    telegram_users: {}
    translations:
      types:
        Task: "Задача"
        Bug: "Ошибка"
        Epic: "Эпик"
      priorities:
        Immediate: "Высочайший"
        High: "Высокий"
        Important: "Важный"
        Normal: "Обычный"
        Low: "Низкий"
      departments:
        Backend: "Бэкенд"
        Frontend: "Фронтенд"
        Design: "Дизайн"
        QA: "Тестирование"
    emojis:
      default: "📋"
      projects: {}
      departments:
        Backend: "⚙️"
        Frontend: "🎨"
        Design: "🖌️"
        QA: "🧪"
      statuses:
        New: "🆕"
        "In progress": "🔧"
        Review: "👀"
        QA: "🧪"
        "On hold": "⏸️"
      types:
        Task: "📝"
        Bug: "🐛"
        Epic: "🏔️"
      priorities:
        Immediate: "🔴"
        High: "🟠"
        Important: "🟡"
        Normal: "🟢"
        Low: "⚪"

# Секция bot опциональна: имя, эмодзи и тексты подставятся из дефолтов.
# bot:
#   name: ""
#   emoji: ""
#   unknown_command_replies: []
#   access_denied_replies: []
#   start_commands: |

schedule:
  enabled: true
  timezone: Asia/Yekaterinburg
  # Без chat_id теги команды не добавляются. Заполни после /chatinfo:
  chat_id:
  message_thread_id:
  # Telegram username'ы (без @), которых не тегать в напоминаниях
  mention_exclude: []
  # Понедельник недели 1 двухнедельного спринта
  sprint_anchor_date: "2026-01-05"
  workday_start: "10:00"
  workday_end: "18:00"
  # texts сообщений не указывай — возьмутся дефолты из кода
  events:
    daily:
      title: Daily
      time: "11:00"
      weekdays: [mon, tue, wed, thu, fri]
      exclude:
        - { sprint_week: 1, weekday: mon }
        - { sprint_week: 2, weekday: fri }
    planning:
      title: Планирование
      time: "19:00"
      weekdays: [mon]
      sprint_weeks: [1]
    release:
      title: Релиз
      time: "20:00"
      weekdays: [thu]
      sprint_weeks: [2]
    retrospective:
      title: Ретроспектива
      time: "15:00"
      weekdays: [fri]
      sprint_weeks: [2]
    workday_end:
      title: Конец рабочего дня
      time: "18:00"
      weekdays: [mon, tue, wed, thu, fri]
