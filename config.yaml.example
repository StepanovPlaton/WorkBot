telegram:
  token: paste-your-telegram-bot-token-here
  allowed_user_ids: []
  proxy:
    enabled: false
    scheme: socks5
    host: ""
    port: 1080
    username: ""
    password: ""

openproject:
  scheme: https
  host: ""
  port:
  base_path: ""
  token: paste-your-openproject-api-token-here
  timeout_seconds: 30
  display:
    story_points_field: storyPoints
    department_field: customField2
    default_boards: {}
    # OpenProject display name → Telegram username (без @)
    telegram_users: {}
    translations:
      types:
        Task: "Задача"
        Bug: "Ошибка"
        Epic: "Эпик"
      priorities:
        Immediate: "Высочайший"
        High: "Высокий"
        Important: "Важный"
        Normal: "Обычный"
        Low: "Низкий"
      departments:
        Backend: "Бэкенд"
        Frontend: "Фронтенд"
        Design: "Дизайн"
        QA: "Тестирование"
    emojis:
      default: "📋"
      projects: {}
      departments:
        Backend: "⚙️"
        Frontend: "🎨"
        Design: "🖌️"
        QA: "🧪"
      statuses:
        New: "🆕"
        "In progress": "🔧"
        Review: "👀"
        QA: "🧪"
        "On hold": "⏸️"
      types:
        Task: "📝"
        Bug: "🐛"
        Epic: "🏔️"
      priorities:
        Immediate: "🔴"
        High: "🟠"
        Important: "🟡"
        Normal: "🟢"
        Low: "⚪"

# Секция bot опциональна: имя, эмодзи и тексты подставятся из дефолтов.
